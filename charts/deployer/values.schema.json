{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "hfTokenSecret": {
      "type": ["null", "string"],
      "description": "Secret name to load the Hugging Face token from"
    },
    "deployer": {
      "type": "object",
      "properties": {
        
        "service": {
          "type": "object",
          "properties": {
            "image": {
              "type": "object",
              "properties": {
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              }
            }
          }
        },
        "ui": {
          "type": "object",
          "properties": {
            "image": {
              "type": "object",
              "properties": {
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              }
            }
          }
        },
        "masterApiKey": {
          "type": "string",
          "description": "Master API key for authentication"
        },
        "kalavaiApi": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "Kalavai API endpoint URL"
            },
            "key": {
              "type": "string",
              "description": "Kalavai API key"
            }
          },
          "required": ["endpoint", "key"]
        },
        "memoryCapPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 95,
          "description": "Memory capacity percentage"
        },
        "gateway": {
          "type": "object",
          "properties": {
            "ui_username": {
              "type": "string",
              "description": "LiteLLM UI username"
            },
            "ui_password": {
              "type": "string",
              "description": "LiteLLM UI password"
            },
            "publicUrl": {
              "type": "string",
              "description": "LiteLLM public URL"
            },
            "internalUrl": {
              "type": ["string", "null"],
              "description": "LiteLLM internal URL"
            },
            "litellm_key": {
              "type": "string",
              "description": "LiteLLM key"
            }
          },
          "required": ["ui_password", "publicUrl", "litellm_key"]
        }
      },
      "required": ["masterApiKey"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable ingress for the UI service"
        },
        "subdomain": {
          "type": "string",
          "default": "spaces.kalavai.net",
          "description": "Subdomain for ingress"
        }
      },
      "required": ["enabled"]
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable horizontal pod autoscaling"
        },
        "service": {
          "type": "object",
          "properties": {
            "minReplicas": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Minimum number of replicas for the service"
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1,
              "default": 3,
              "description": "Maximum number of replicas for the service"
            },
            "targetCPUUtilization": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 70,
              "description": "Target CPU utilization percentage for the service"
            },
            "targetMemoryUtilization": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 80,
              "description": "Target memory utilization percentage for the service"
            }
          },
          "required": ["minReplicas", "maxReplicas", "targetCPUUtilization", "targetMemoryUtilization"]
        },
        "ui": {
          "type": "object",
          "properties": {
            "minReplicas": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Minimum number of replicas for the UI"
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1,
              "default": 2,
              "description": "Maximum number of replicas for the UI"
            },
            "targetCPUUtilization": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 70,
              "description": "Target CPU utilization percentage for the UI"
            },
            "targetMemoryUtilization": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 80,
              "description": "Target memory utilization percentage for the UI"
            }
          },
          "required": ["minReplicas", "maxReplicas", "targetCPUUtilization", "targetMemoryUtilization"]
        }
      },
      "required": ["enabled"]
    },
    "system": {
      "type": "object",
      "properties": {
        "envFromSecrets": {
            "type": "object",
            "description": "Dictionary mapping environment variable names to secret names"
        },
        "priorityClassName": {
          "type": ["string", "null"],
          "default": "user-spot-priority",
          "description": "Priority class name for pods"
        },
        "nodeSelectors": {
          "type": ["array", "null"],
          "description": "Node selectors for pod scheduling",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Node selector key"
              },
              "value": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Node selector values"
              }
            },
            "required": ["name", "value"]
          }
        },
        "nodeSelectorsOps": {
          "type": "string",
          "enum": ["OR", "AND"],
          "default": "OR",
          "description": "Node selector operation (OR or AND)"
        },
        "jobId": {
          "type": "string",
          "description": "Job ID for labeling resources"
        }
      }
    }
  },
  "required": ["hfTokenSecret"]
}
