{
   "$schema": "http://json-schema.org/draft-07/schema#",
   "type": "object",
   "properties": {
      "version": {
         "type": "string",
         "description": "JupyterHub version to install"
      },
      "singleuser": {
         "type": "object",
         "properties": {
            "image": {
               "type": "object",
               "properties": {
                  "name": {
                     "type": "string",
                     "description": "JupyterHub image name"
                  },
                  "imagePullSecrets": {
                     "type": [
                        "object",
                        "null"
                     ],
                     "description": "Image pull secrets"
                  }
               }
            },
            "gpuCount": {
               "type": "integer",
               "description": "GPU count"
            },
            "memory": {
               "type": "number",
               "description": "Memory"
            },
            "cpu": {
               "type": "number",
               "description": "CPU"
            },
            "storageCapacity": {
               "type": "number",
               "description": "Storage capacity"
            },
            "storageClass": {
               "type": "string",
               "description": "Storage class"
            },
            "initScript": {
               "type": "string",
               "description": "Initialization script"
            }
         }
      },
      "system": {
         "properties": {
            "priorityClassName": {
               "type": "string",
               "description": "PriorityClassName to use for the deployment"
            },
            "nodeSelectors": {
               "type": [
                  "object",
                  "null"
               ],
               "description": "target specific devices. Expected format -> key: value pairs, where 'value' is a list of elements"
            },
            "nodeSelectorsOps": {
               "type": "string",
               "enum": [
                  "OR",
                  "AND"
               ],
               "description": "Logical operation to use to apply to nodeSelectors. Accepted values: 'OR', 'AND'"
            },
            "jobId": {
               "type": "string",
               "description": "Id to tag spawned objects."
            }
         }
      }
   },
   "required": []
}