{
   "$schema": "http://json-schema.org/draft-07/schema#",
   "type": "object",
   "properties": {
      "singleuser": {
         "type": "object",
         "properties": {
            "username": {
               "type": "string",
               "description": "Username for the single user (non-admin)"
            },
            "adminUsername": {
               "type": "string",
               "description": "Admin username for the hub"
            },
            "password": {
               "type": "string",
               "description": "Password shared with user and admin accounts"
            },
            "image": {
               "type": "object",
               "properties": {
                  "name": {
                     "type": "string",
                     "description": "JupyterHub image name"
                  },
                  "imagePullSecrets": {
                     "type": [
                        "object",
                        "null"
                     ],
                     "description": "Image pull secrets"
                  }
               }
            },
            "gpuCount": {
               "type": "integer",
               "description": "GPU count"
            },
            "memory": {
               "type": "number",
               "description": "Memory"
            },
            "cpu": {
               "type": "number",
               "description": "CPU"
            },
            "storageCapacity": {
               "type": "number",
               "description": "Storage capacity"
            },
            "storageClass": {
               "type": "string",
               "description": "Storage class"
            },
            "initScript": {
               "type": "string",
               "description": "Initialization script"
            }
         }
      },
      "distributed": {
         "type": "object",
         "properties": {
            "enabled": {
               "type": "boolean",
               "description": "Enable distributed mode"
            },
            "minGpus": {
               "description": "Minimum GPU workers to always have running (can be 0). 1 worker == 1 GPU",
               "type": "integer"
            },
            "maxGpus": {
               "description": "Maximum GPU workers to allow scaling up to.",
               "type": "integer"
            },
            "rayVersion": {
               "description": "Ray PIP version to use in the cluster (e.g. 2.49.0)",
               "type": "string"
            },
            "pythonVersion": {
               "description": "Python version to use in the cluster (39, 310, 311, 312)",
               "type": "string",
               "enum": ["39", "310", "311", "312"]
            },
            "cudaVersion": {
               "description": "CUDA version to use in the cluster (117 to 128)",
               "type": "string",
               "enum": ["117", "118", "121", "123", "124", "125", "126", "128"]
            },
            "idleTimeoutSeconds": {
               "description": "Defines the waiting time in seconds before scaling down an idle worker pod. Aggressive. https://docs.ray.io/en/latest/cluster/kubernetes/user-guides/configuring-autoscaling.html#scale-up-and-scale-down-speed",
               "type": "integer"
            }
         }
      },
      "ingress": {
         "type": "object",
         "properties": {
            "enabled": {
               "type": "boolean",
               "description": "Enable ingress"
            },
            "subdomain": {
               "type": "string",
               "description": "Subdomain for the ingress"
            }
         }
      },
      "system": {
         "properties": {
            "priorityClassName": {
               "type": "string",
               "description": "PriorityClassName to use for the deployment"
            },
            "nodeSelectors": {
               "type": [
                  "object",
                  "null"
               ],
               "description": "target specific devices. Expected format -> key: value pairs, where 'value' is a list of elements"
            },
            "nodeSelectorsOps": {
               "type": "string",
               "enum": [
                  "OR",
                  "AND"
               ],
               "description": "Logical operation to use to apply to nodeSelectors. Accepted values: 'OR', 'AND'"
            },
            "jobId": {
               "type": "string",
               "description": "Id to tag spawned objects."
            }
         }
      }
   },
   "required": []
}