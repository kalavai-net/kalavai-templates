{
   "$schema": "http://json-schema.org/draft-07/schema#",
   "type": "object",
   "properties": {
      "watcher": {
         "type": "object",
         "properties": {
            "enabled": {
               "type": "boolean",
               "description": "Enable Kube watcher"
            },
            "version": {
               "description": "Kube watcher version to install in the pool",
               "type": "string"
            },
            "imageTag": {
               "description": "Kube watcher image tag to install in the pool",
               "type": "string",
               "enum": ["2026.3.3", "latest"]
            },
            "adminKey": {
               "description": "Kube watcher admin key (full privileges)",
               "type": "string"
            },
            "writeKey": {
               "description": "Kube watcher write key (full namespace privileges)",
               "type": "string"
            },
            "readonlyKey": {
               "description": "Kube watcher readonly key (read only privileges)",
               "type": "string"
            }
         }
      },
      "kalavaiApi": {
         "type": "object",
         "properties": {
            "enabled": {
               "type": "boolean",
               "description": "Enable Kalavai API"
            },
            "forceCutoffMetricsDate": {
               "type": ["string", "null"],
               "description": "Force cutoff metrics date, format: YYYY-MM-DDTHH:MM:SSZ"
            },
            "version": {
               "description": "Kalavai API service version to install in the pool",
               "type": "string"
            },
            "imageTag": {
               "description": "Kalavai API service image tag to install in the pool",
               "type": "string",
               "enum": ["0.8.19", "latest"]
            },
            "forcedNamespace": {
               "description": "Whether to force the API to only have single namespace access",
               "type": "boolean"
            },
            "ringfenceNodeLabel": {
               "description": "Kalavai API service to ringfence nodes based on node label",
               "type": ["string", "null"]
            },
            "ringfenceNodeLabelValue": {
               "description": "Kalavai API service to ringfence nodes based on node label value",
               "type": ["string", "null"]
            },
            "forcedPriority": {
               "description": "Whether to force the API to deploy with a single priority class",
               "type": "string",
               "enum": ["kalavai-system-priority", "user-high-priority", "user-spot-priority", "test-low-priority", "test-high-priority"]
            }
         }
      },
      "ui": {
         "type": "object",
         "properties": {
            "enabled": {
               "type": "boolean",
               "description": "Enable UI"
            },
            "accessKeyType": {
               "type": "string",
               "description": "Access key type for UI",
               "enum": ["admin", "write", "read"]
            },
            "cpu": {
               "type": "number",
               "description": "CPU request for UI"
            },
            "memory": {
               "type": "number",
               "description": "Memory request for UI"
            },
            "showResources": {
               "type": "boolean",
               "description": "Show resources page in UI (providers only)"
            },
            "showMonitoring": {
               "type": "boolean",
               "description": "Show monitoring page in UI (providers only)"
            },
            "showUserSpaces": {
               "type": "boolean",
               "description": "Show user spaces page in UI (providers only)"
            }
         }
      },
      "ingress": {
         "type": "object",
         "properties": {
            "enabled": {
               "type": "boolean",
               "description": "Enable ingress for the UI"
            },
            "subdomain": {
               "type": "string",
               "description": "Subdomain for ingress"
            }
         }
      },
      "system": {
         "properties": {
            "envFromSecrets": {
               "type": "array",
               "description": "List of secret names to mount as environment variables"
            },
            "priorityClassName": {
               "type": "string",
               "description": "PriorityClassName to use for the deployment"
            },
            "nodeSelectors": {
               "type": [
                  "object",
                  "null"
               ],
               "description": "target specific devices. Expected format -> key: value pairs, where 'value' is a list of elements"
            },
            "nodeSelectorsOps": {
               "type": "string",
               "enum": [
                  "OR",
                  "AND"
               ],
               "description": "Logical operation to use to apply to nodeSelectors. Accepted values: 'OR', 'AND'"
            },
            "jobId": {
               "type": "string",
               "description": "Id to tag spawned objects."
            }
         }
      }
   },
   "required": [
      "watcher",
      "kalavaiApi"
   ]
}